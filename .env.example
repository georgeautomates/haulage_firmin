# ─── AI (OpenRouter — routes to OpenAI models) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-...
AI_EXTRACTION_MODEL=openai/gpt-4o-mini
AI_LOCATION_MODEL=openai/gpt-4o

# To switch to Anthropic later, replace the three lines above with:
# ANTHROPIC_API_KEY=sk-ant-...
# AI_EXTRACTION_MODEL=claude-haiku-3-5
# AI_LOCATION_MODEL=claude-sonnet-4-6

# ─── Supabase (Postgres connection string) ───────────────────────────────────
SUPABASE_POSTGRES_DSN=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Gmail API ───────────────────────────────────────────────────────────────
GMAIL_TOKEN_PATH=config/gmail_token.json
GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json

# ─── Google Sheets (service account) ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_PATH=config/service_account.json

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Agent settings ──────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
